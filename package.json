{
  "name": "skyagent",
  "version": "0.1.0",
  "description": "Codex plugin, CLI, and MCP tools for Hypixel SkyBlock profile analysis.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "skyagent": "./scripts/skyagent.ts"
  },
  "scripts": {
    "check": "bun run typecheck && bun run smoke",
    "ci": "bun run check && bun run validate:plugin && bun run validate:skill",
    "typecheck": "tsc --noEmit",
    "smoke": "bun ./scripts/skyagent.ts skycrypt Notch Apple",
    "validate:plugin": "bun ./scripts/ci/validate-plugin.ts",
    "validate:skill": "bun ./scripts/ci/validate-skill.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@skyagent/cli": "workspace:*",
    "@skyagent/core": "workspace:*",
    "@skyagent/mcp": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
