{
  "name": "skyagent",
  "version": "0.1.0",
  "description": "Codex plugin, CLI, and MCP tools for Hypixel SkyBlock profile analysis.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/marius-patrik/skyagent.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "skyagent": "./scripts/skyagent.ts"
  },
  "scripts": {
    "check": "bun run typecheck && bun run test && bun run smoke",
    "ci": "bun run check && bun run validate:plugin && bun run validate:skill && bun run build:release -- --current && bun run smoke:release",
    "build:web": "bun run --cwd packages/web build",
    "build:release": "bun ./scripts/build-release.ts",
    "dev:web": "bun run --cwd packages/web dev",
    "visual:web": "bun run --cwd packages/web visual:qa",
    "release:metadata": "bun ./scripts/write-release-metadata.ts",
    "release:plan": "bun ./scripts/plan-release.ts",
    "tui": "bun ./packages/tui/src/bin.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "smoke": "bun ./scripts/skyagent.ts skycrypt Notch Apple && bun ./scripts/skyagent.ts tui --smoke",
    "smoke:release": "bun ./scripts/smoke-release.ts",
    "validate:plugin": "bun ./scripts/ci/validate-plugin.ts",
    "validate:skill": "bun ./scripts/ci/validate-skill.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@skyagent/cli": "workspace:*",
    "@skyagent/core": "workspace:*",
    "@skyagent/gateway": "workspace:*",
    "@skyagent/mcp": "workspace:*",
    "@skyagent/tui": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  }
}
